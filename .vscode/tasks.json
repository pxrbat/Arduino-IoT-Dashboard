{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile",
            "type": "shell",
            "command": "arduino-cli compile --fqbn arduino:avr:uno .",
            "group": "build"
        },
        {
            "label": "Upload",
            "type": "shell",
            "command": "arduino-cli upload -p /dev/ttyACM0 --fqbn arduino:avr:uno ."
        },
        {
            "label": "Monitor",
            "type": "shell",
            "command": "arduino-cli monitor -p /dev/ttyACM0 -c baudrate=9600"
        }
    ]
}
